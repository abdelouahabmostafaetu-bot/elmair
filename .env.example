# ==========================================================
#  Al-Meiyar Center - Environment Variables
#  Copy this file to .env.local for local development.
#  On Vercel, add these in: Project Settings > Environment Variables
# ==========================================================

# Email of the site administrator (only this account can open /admin)
ADMIN_EMAIL=contact.almeiyar@gmail.com

# Clerk authentication keys (from dashboard.clerk.com)
CLERK_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
CLERK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx

# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB=almeiyar

# Public site URL (optional)
FRONTEND_URL=https://your-site.vercel.app

# Not required on Vercel (it manages the port automatically)
PORT=3000
